# Database Configuration (PostgreSQL - Optional, for local development)
DB_HOST=/cloudsql/YOUR_PROJECT:REGION:INSTANCE_NAME
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_NAME=your_database_name

# Google Cloud Platform
GCP_PROJECT=your-gcp-project-id

# WxTech Weather API (Required for weather forecasting)
# Get your API key from: https://wxtech.weathernews.com/
WXTECH_API_KEY=your_wxtech_api_key_here
