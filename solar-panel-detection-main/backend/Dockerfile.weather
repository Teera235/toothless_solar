FROM python:3.11-slim

WORKDIR /app

# Copy requirements and install basic dependencies
COPY requirements.txt .
RUN pip install --no-cache-dir fastapi uvicorn aiohttp python-dotenv pydantic

# Copy API files
COPY api_weather_only.py .
COPY weather_service.py .
COPY .env .

# Expose port
EXPOSE 8080

# Run weather-only API
CMD ["uvicorn", "api_weather_only:app", "--host", "0.0.0.0", "--port", "8080"]